STORAGE_PATH=/data
# Fjall persistence mode for local storage and Irokle metadata state.
# Use sync_all for fsync-backed local durability at higher write latency.
ARUNA_FJALL_PERSIST_MODE=buffer
SOCKET_ADDRESS=127.0.0.1:3000
P2P_SOCKET_ADDRESS=127.0.0.1:3001
S3_HOST=127.0.0.1:1337
S3_ADDRESS=127.0.0.1:1337
REALM_DESCRIPTION="Compose Realm"
OIDC_PROVIDER_IDS=main
OIDC_MAIN_ISSUER=http://localhost:8080/realms/aruna
OIDC_MAIN_AUDIENCE=aruna-api
OIDC_MAIN_DISCOVERY_URL=http://localhost:8080/realms/aruna/.well-known/openid-configuration
RUST_LOG=info
